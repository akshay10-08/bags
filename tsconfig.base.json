{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@conviction/shared": ["packages/shared/src/index.ts"],
      "@conviction/shared/*": ["packages/shared/src/*"],
      "@conviction/agents": ["packages/agents/src/index.ts"],
      "@conviction/agents/*": ["packages/agents/src/*"]
    }
  }
}
